[
  {
    "name": "Set Quiet Hours shows current config and prompt",
    "steps": [
      {
        "send": { "callback": "quiet_hours:set" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Quiet hours are not set.\n\nEnter the start time for quiet hours (HH:MM, 24h format, e.g. 22:00):"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Set Quiet Hours full flow",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "👋 Welcome! Tap a button below to get started." } }
        ]
      },
      {
        "send": { "callback": "quiet_hours:set" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]

[
  {
    "name": "/admin shows the admin dashboard",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📊 Admin Dashboard\n\nWatchlist tickers: 0\nTotal alerts: 0 (0 active)\n\nNo alert data yet."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/admin shows metrics after onboarding",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "👋 Welcome! Tap a button below to get started." } }
        ]
      },
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📊 Admin Dashboard\n\nWatchlist tickers: 3\nTotal alerts: 1 (1 active)\n\nTop tickers by alert count:\n  ETH: 1"
            }
          }
        ]
      }
    ]
  }
]
